rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /quizzes/{quizId} {
      allow read, write: if true;
      match /questions/{questionId} {
        allow read, write: if true;
      }
    }

    match /users/{userId} {
      allow read, write: if true;
    }

    // Resultados de quizzes respondidos pelos alunos
    match /results/{resultId} {
      allow read, write: if true;
    }
  }
}
